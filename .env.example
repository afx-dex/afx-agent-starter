# testnet is the default. Use mainnet only after reviewing risk settings.
AFX_ENV=testnet

# Trading is disabled by default. Keep this false while developing strategies.
AFX_ENABLE_TRADING=false

# Required by the SDK. Use testnet-only wallets while experimenting.
AFX_MASTER_PRIVATE_KEY=
AFX_AGENT_PRIVATE_KEY=

# Optional network/proxy settings.
AFX_PROXY_URL=
AFX_TIMEOUT_MS=15000

# Starter strategy settings.
AFX_SYMBOL=BTCUSDC
AFX_ORDER_QTY=0.001
AFX_ORDER_PRICE=
AFX_SIDE=BUY
AFX_MAX_NOTIONAL_USDC=100
AFX_MAX_LEVERAGE=3
