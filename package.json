{
  "name": "@afx-dex/afx-agent-starter",
  "version": "0.1.0",
  "private": true,
  "description": "A safe TypeScript starter for building trading agents on AFX.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afx-dex/afx-agent-starter.git"
  },
  "bugs": {
    "url": "https://github.com/afx-dex/afx-agent-starter/issues"
  },
  "homepage": "https://github.com/afx-dex/afx-agent-starter#readme",
  "scripts": {
    "dev": "tsx src/agent.ts",
    "start": "node dist/agent.js",
    "build": "tsup src/agent.ts src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@afx-dex/afx-js-sdk": "github:afx-dex/afx-js-sdk#main",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
